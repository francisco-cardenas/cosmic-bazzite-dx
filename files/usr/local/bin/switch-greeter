#!/usr/bin/env bash
# Switch the display manager between gdm and cosmic-greeter
#
# Usage:
#   sudo switch-greeter [--gdm | --cosmic | --status]

set -euo pipefail

info()  { echo -e "\e[1;34m[INFO]\e[0m $*" >&2; }
warn()  { echo -e "\e[1;33m[WARN]\e[0m $*" >&2; }
error() { echo -e "\e[1;31m[ERROR]\e[0m $*" >&2; }

usage() {
  cat <<'EOF'
Usage:
  switch-greeter [--gdm | --cosmic | --status]

Options:
  --gdm     Switch to GDM (GNOME Display Manager)
  --cosmic  Switch to cosmic-greeter
  --status  Show the currently enabled display manager
  -h, --help  Show this help
EOF
}

require_root() {
  if [[ "${EUID}" -ne 0 ]]; then
    error "Please run as root (sudo $0)."
    exit 1
  fi
}

current_greeter() {
  local dm_link
  dm_link="$(readlink /etc/systemd/system/display-manager.service 2>/dev/null || true)"
  case "$dm_link" in
    */gdm.service)            echo "gdm" ;;
    */cosmic-greeter.service) echo "cosmic-greeter" ;;
    "")
      # Fallback: check enabled state
      if systemctl is-enabled gdm &>/dev/null; then
        echo "gdm"
      elif systemctl is-enabled cosmic-greeter &>/dev/null; then
        echo "cosmic-greeter"
      else
        echo "unknown"
      fi
      ;;
    *) echo "unknown ($dm_link)" ;;
  esac
}

do_switch() {
  local target="$1"
  local current
  current="$(current_greeter)"

  if [[ "$current" == "$target" ]]; then
    info "Already using $target — nothing to do."
    exit 0
  fi

  info "Current display manager: $current"
  info "Switching to: $target"

  # Disable the current one (if known)
  case "$current" in
    gdm)            systemctl disable gdm ;;
    cosmic-greeter) systemctl disable cosmic-greeter ;;
  esac

  # Enable the target
  case "$target" in
    gdm)            systemctl enable gdm ;;
    cosmic-greeter) systemctl enable cosmic-greeter ;;
  esac

  info "Done. Active display manager after next boot: $target"

  if ugum confirm "Restart the display manager now?"; then
    info "Restarting display manager..."
    systemctl start "$target"
  else
    info "Changes take effect on next login or reboot."
  fi
}

TARGET=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --gdm)    TARGET="gdm"; shift ;;
    --cosmic) TARGET="cosmic-greeter"; shift ;;
    --status) current_greeter; exit 0 ;;
    -h|--help) usage; exit 0 ;;
    *) error "Unknown argument: $1"; usage; exit 1 ;;
  esac
done

require_root

if [[ -z "$TARGET" ]]; then
  current="$(current_greeter)"
  echo -e "\e[1;36mCurrent display manager:\e[0m $current"
  echo ""

  choice="$(ugum choose "gdm (GNOME Display Manager)" "cosmic-greeter (COSMIC Greeter)")"
  case "$choice" in
    gdm*)            TARGET="gdm" ;;
    cosmic-greeter*) TARGET="cosmic-greeter" ;;
    *) error "Invalid choice."; exit 1 ;;
  esac
fi

do_switch "$TARGET"
